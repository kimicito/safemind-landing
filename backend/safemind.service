[Unit]
Description=SafeMind Backend API
After=network.target postgresql.service

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/safemind
Environment=PATH=/opt/safemind/venv/bin
ExecStart=/opt/safemind/venv/bin/uvicorn backend.main:app --host 127.0.0.1 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
